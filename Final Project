    // loads events here

    public ArrayList<Event> loadEvents() {

        ArrayList<Event> list = new ArrayList<Event>();

        try {

            Scanner input = new Scanner(new File("events.txt"));

            while (input.hasNextLine()) {

                String line = input.nextLine();
                String[] p = line.split(",");

                if (p.length == 5) {

                    list.add(new Event(
                            p[0],
                            Integer.parseInt(p[1]),
                            Integer.parseInt(p[2]),
                            Integer.parseInt(p[3]),
                            Integer.parseInt(p[4])
                    ));
                }
            }

            input.close();

        } catch (Exception e) {
            System.out.println("Error loading events.");
        }

        return list;
    }

    // prints file here

    public void printFile(String fileName) {

        try {

            Scanner input = new Scanner(new File(fileName));

            System.out.println();

            while (input.hasNextLine()) {
                System.out.println(input.nextLine());
            }

            input.close();

        } catch (Exception e) {
            System.out.println("Could not open " + fileName);
        }
    }

    // saves game here

    public void saveGame(Soldier s, int day,
                         boolean radio, boolean map, boolean pilot) {

        try {

            PrintWriter out = new PrintWriter("savegame.txt");

            out.println(s.health);
            out.println(s.energy);
            out.println(s.hunger);
            out.println(s.stealth);
            out.println(s.distance);
            out.println(s.rations);

            out.println(day);
            out.println(radio);
            out.println(map);
            out.println(pilot);

            out.close();

        } catch (Exception e) {
            System.out.println("Save error.");
        }
    }

    // loads save here

    public SaveData loadGame() {

        try {

            Scanner in = new Scanner(new File("savegame.txt"));

            Soldier s = new Soldier();

            s.health = Integer.parseInt(in.nextLine());
            s.energy = Integer.parseInt(in.nextLine());
            s.hunger = Integer.parseInt(in.nextLine());
            s.stealth = Integer.parseInt(in.nextLine());
            s.distance = Integer.parseInt(in.nextLine());
            s.rations = Integer.parseInt(in.nextLine());

            SaveData data = new SaveData();

            data.player = s;
            data.day = Integer.parseInt(in.nextLine());
            data.hasRadio = Boolean.parseBoolean(in.nextLine());
            data.hasMap = Boolean.parseBoolean(in.nextLine());
            data.rescuedPilot = Boolean.parseBoolean(in.nextLine());

            in.close();

            return data;

        } catch (Exception e) {
            return null;
        }
    }
}
